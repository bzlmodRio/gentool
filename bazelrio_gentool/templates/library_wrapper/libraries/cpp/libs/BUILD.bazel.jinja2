{% if target.get_shared_library_select() != "," %}
alias(
    name = "shared",
    actual = select({
{{target.get_shared_library_select()}}
    }),
    visibility = ["//visibility:public"],
)
{% else %}
# No shared libraries?
{% endif %}

{%- if target.has_jni %}

alias(
    name = "jni",
    actual = select({
{{target.get_jni_shared_library_select()}}
    }),
    visibility = ["//visibility:public"],
)
{%- endif %}

