load("@rules_cc//cc:defs.bzl", "cc_library")

alias(
    name = "{{target.parent_folder}}",
    actual = {% if target.get_shared_library_select() != "," %}":shared"{% else %}":static"{%endif%},
    visibility = {{ visibility }},
)
